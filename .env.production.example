# Call Master Control Tower - Production Environment Template
# COPY THIS FILE TO .env AND FILL IN REAL VALUES
# NEVER COMMIT .env TO GIT

# =============================================================================
# DATABASE CONFIGURATION (REQUIRED - REAL MySQL CREDENTIALS ONLY)
# =============================================================================
DB_HOST=122.184.128.90
DB_PORT=3306
DB_USER=your_production_username
DB_PASSWORD=your_secure_production_password

# Database Names (REAL DATABASES)
DB_APP=Shivamgiri
DB_EXTERNAL=db_external
DB_AUDIT=db_audit

# =============================================================================
# API CONFIGURATION
# =============================================================================
PORT=5000
NODE_ENV=production

# =============================================================================
# AUTHENTICATION (USE JWT FOR PRODUCTION)
# =============================================================================
AUTH_MODE=jwt
JWT_SECRET=generate_32_plus_character_random_string_here
JWT_EXPIRY=24h

# Generate JWT_SECRET:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGIN=https://yourdomain.com

# =============================================================================
# CRITICAL SECURITY RULES
# =============================================================================
# 1. ALL DATA FROM REAL MySQL - NO MOCK DATA
# 2. db_external and db_audit are READ-ONLY (SELECT only)
# 3. ALL WRITES to DB_APP (Shivamgiri.ci_* tables only)
# 4. Rotate DB_PASSWORD every 90 days
# 5. NEVER commit .env to git (check .gitignore)
# 6. JWT_SECRET must be 32+ random characters
# 7. AUTH_MODE must be 'jwt' (not 'mock') in production
# 8. CORS_ORIGIN must match production frontend domain

# =============================================================================
# DATABASE ACCESS RULES
# =============================================================================
# READ-ONLY:
#   - db_external.CallDetails
#   - db_audit.call_quality_assessment
#   - Shivamgiri.dialer_db.*
#   - Shivamgiri.users (auth only)
#
# WRITE:
#   - Shivamgiri.ci_call_master
#   - Shivamgiri.ci_coaching_triggers
#   - Shivamgiri.ci_governance_actions
#   - Shivamgiri.cm_process_daily_summary

